rules_version = '2';

// Firestore security rules for the Kres portfolio.
//
// Data model:
//   users/{uid}           -> { username, isAdmin, status, createdAt }
//                            status: 'pending' | 'approved' | 'rejected'
//   usernames/{name}      -> { uid, createdAt }   (unique username guard)
//   portfolio/{content}   -> { aboutBody, projects, skills, contacts, updatedAt }
//   analytics/portfolio   -> { totalViews, updatedAt }
//   analytics/viewers/{uid} -> { username, views, firstSeen, lastSeen }
//
// Auth model:
//   Firebase Auth email/password. email = "<username>@portfolio.local".
//   New users register with status='pending'; admin approves/rejects.
//   isAdmin is a boolean set ONLY at bootstrap.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ---- User profiles ----
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && request.resource.data.username.size() <= 20
        && request.resource.data.isAdmin == false
        && (request.resource.data.status is string
            ? request.resource.data.status == 'pending'
            : true);
      // Admin can update any field (including status for approve/reject).
      // A user may NOT change their own status/isAdmin.
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---- Username uniqueness map ----
    match /usernames/{name} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ---- Portfolio content ----
    match /portfolio/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- Analytics ----
    // Total view counter: admin reads; any signed-in user may increment.
    match /analytics/portfolio {
      allow read: if isAdmin();
      allow update: if isSignedIn();
      allow create: if isSignedIn();
    }
    // Per-viewer record: admin reads all; a user creates/updates only their own.
    match /analytics/viewers/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
    }
  }
}
