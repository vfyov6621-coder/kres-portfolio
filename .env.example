# Firebase client config (PUBLIC values — safe to ship in a static build).
# Copy this file to `.env.local` and fill in the values from:
#   Firebase Console → Project settings → Your apps → SDK setup and configuration.
#
# For local dev WITHOUT a real Firebase project, set the demo values below
# and NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true, then run `bun run emulators`.

NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=kres-portfolio.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=kres-portfolio
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=kres-portfolio.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Set to "true" to point the client SDK at the local Firebase emulators.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true

# GitHub Pages: set this to "/<your-repo-name>" when building for a project
# site (https://<user>.github.io/<repo>/). Leave empty for dev or for a
# user/org root site (https://<user>.github.io/) or a custom domain.
NEXT_PUBLIC_BASE_PATH=
